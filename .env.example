# Variáveis de Ambiente - Hora do Lanche
# Copie este arquivo para .env e configure conforme necessário

# Servidor
NODE_ENV=development
PORT=3000
HOST=localhost

# Banco de Dados (futuro)
DATABASE_URL=mongodb://localhost:27017/hora_do_lanche
DB_NAME=hora_do_lanche
DB_USER=admin
DB_PASSWORD=password

# IA e APIs (futuro)
OPENAI_API_KEY=sua-chave-aqui
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7

# Pagamento (futuro)
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx

# Email (futuro)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha

# Geolocalização
GOOGLE_MAPS_API_KEY=sua-chave-aqui

# Autenticação
JWT_SECRET=sua-chave-secreta-muito-segura-aqui

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Delivery (futuro)
DELIVERY_API_URL=https://api.delivery-service.com
DELIVERY_API_KEY=sua-chave-aqui

# Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Modo Debug
DEBUG=false

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://horadelanche.com
